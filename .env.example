# KRAIT Environment Variables
# Copy this file to .env and fill in your values

# Required — OpenRouter API key for LLM access (multi-model, cost tracking)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Legacy fallback (deprecated): ANTHROPIC_API_KEY is also accepted during migration

# API authentication token (required in prod)
KRAIT_API_TOKEN=your-secret-token-here

# Admin token for kill switch and admin API routes (required in prod)
# KRAIT_ADMIN_TOKEN=your-admin-secret-here

# Prevent crash dumps from writing sensitive state to disk
ERL_CRASH_DUMP=/dev/null

# Optional — Narsil MCP binary path (deep security analysis)
# Defaults to searching PATH, then ../narsil-mcp/target/release/narsil-mcp
# NARSIL_BINARY=/path/to/narsil-mcp

# Optional — enables real GitHub PRs (omit for dry-run mode)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# KRAIT_REPO_NAME=your-org/krait

# Optional — PostgreSQL (defaults to postgres/postgres@localhost/krait_dev)
# DATABASE_URL=ecto://postgres:postgres@localhost/krait_dev

# Optional — Telegram bot (omit to disable)
# TELEGRAM_BOT_TOKEN=
